# Afriwork credentials
AFRIWORK_EMAIL=your-email@example.com
AFRIWORK_PASSWORD=your-password

AFRIWORK_BASE_URL=https://afriworket.com/

# Database Configuration (Turso LibSQL)
DATABASE_URL=libsql://your-database-name.turso.io
DATABASE_AUTH_TOKEN=your-database-auth-token

# Telegram Bot
BOT_TOKEN=your-telegram-bot-token
BASE_URL=your-webhook-url

# AI Configuration
AI_PROVIDER=openai

# API Keys (add the one you're using)
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-key
GROQ_API_KEY=your-groq-key

MODEL=model_name_they_want_to_use